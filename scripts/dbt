#!/usr/bin/env bash
set -euo pipefail

ROOT=$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)
DBT_BIN=${FS_DBT_BIN:-/Users/dataders/Developer/fs.clickhouse-clean-materialized-views/target/debug/dbt}
ARTIFACT_ROOT=${DBT_ARTIFACT_ROOT:-/private/tmp/dbt-fusion-clickhouse-demo}

[ -x "$DBT_BIN" ] || {
  printf 'missing executable dbt binary: %s\n' "$DBT_BIN" >&2
  exit 1
}

[ -f "$ROOT/.env" ] && {
  set -a
  # shellcheck disable=SC1091
  source "$ROOT/.env"
  set +a
}

mkdir -p "$ARTIFACT_ROOT/target" "$ARTIFACT_ROOT/logs"

clickhouse_query() {
  local sql=$1
  curl -fsS -u "$CLICKHOUSE_KEY_ID:$CLICKHOUSE_KEY_SECRET" \
    "https://$CLICKHOUSE_HOST:${CLICKHOUSE_PORT:-8443}/" \
    --data-binary "$sql" >/dev/null
}

drop_demo_model_relations() {
  command -v curl >/dev/null 2>&1 || return 0
  [ -n "${CLICKHOUSE_HOST:-}" ] || return 0
  [ -n "${CLICKHOUSE_KEY_ID:-}" ] || return 0
  [ -n "${CLICKHOUSE_KEY_SECRET:-}" ] || return 0

  clickhouse_query "DROP TABLE IF EXISTS clickstream.fct_market_odds_mv"
  clickhouse_query "DROP TABLE IF EXISTS clickstream.fct_market_odds"
  clickhouse_query "DROP TABLE IF EXISTS clickstream.int_bet_markets_mv"
  clickhouse_query "DROP TABLE IF EXISTS clickstream.int_bet_markets"
  clickhouse_query "DROP TABLE IF EXISTS clickstream.stg_bets_mv"
  clickhouse_query "DROP TABLE IF EXISTS clickstream.stg_bets"
}

if [ "${1:-}" = "run" ] && [ "${DBT_DEMO_SKIP_PRE_RUN_CLEAN:-0}" != "1" ]; then
  drop_demo_model_relations
fi

exec "$DBT_BIN" \
  --project-dir "$ROOT" \
  --profiles-dir "$ROOT" \
  --target-path "$ARTIFACT_ROOT/target" \
  --log-path "$ARTIFACT_ROOT/logs" \
  --no-write-json \
  "$@"
